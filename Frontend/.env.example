# Backend URL that the Vite dev proxy forwards `/api/*` to.
#
# Default (when this var is unset) is `http://localhost:8000` — the local
# FastAPI server started with `uvicorn app:app --port 8000`.
#
# For the Colab demo path (see colab/README.md), set this to the Cloudflare
# quick-tunnel URL printed by the notebook, e.g.:
#
#   VITE_BACKEND_URL=https://random-three-words.trycloudflare.com
#
# Pass it inline when starting the dev server (recommended — avoids committing
# a real URL to .env), e.g.:
#
#   VITE_BACKEND_URL=https://...trycloudflare.com npm run dev
#
# Note: this is read by `vite.config.ts` (Node side) at startup. Restart the
# dev server after changing it.
VITE_BACKEND_URL=http://localhost:8000
